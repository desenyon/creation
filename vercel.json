{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix website",
  "buildCommand": "cp install.sh website/public/install.sh && npm run build --prefix website",
  "outputDirectory": "website/.next",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/install.sh",
      "headers": [{ "key": "Content-Type", "value": "text/x-shellscript; charset=utf-8" }]
    }
  ]
}
