# 1 — Composio
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=creation-user-001
COMPOSIO_GITHUB_AUTH_CONFIG_ID=ac_
COMPOSIO_LINEAR_AUTH_CONFIG_ID=ac_
COMPOSIO_GMAIL_AUTH_CONFIG_ID=ac_
COMPOSIO_FIRECRAWL_AUTH_CONFIG_ID=ac_

# 2 — Tavily (required)
TAVILY_API_KEY=

# 3 — Nebius (required)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Mem0 — persistent memory (pairs with SuperCompress per turn)
MEM0_API_KEY=

# Gmail notify address (kickoff + per-turn + completion emails via Composio)
GMAIL_NOTIFY_TO=you@example.com

# 4 — Coding runtime — OpenClaw, Codex, and Claude Code use local CLI login
#    43 agents registered — run `creation doctor` to see what's on PATH

CREATION_DEMO=0
